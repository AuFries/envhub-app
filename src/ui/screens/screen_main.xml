<screen>
  <styles>
    <style name="style_main" bg_color="0xE8EFF2" />

    <style name="header_panel"
          bg_color="0x2F6F7E"
          border_width="0"
          radius="16"/>

    <style name="tile_panel"
          bg_color="0xFFFFFF"
          border_width="1"
          border_color="0xD6E0E5"
          radius="14"/>

    <style name="status_panel"
          bg_color="0x2F6F7E"
          border_width="0"
          radius="16"/>

    <style name="wrap_plain"
          bg_opa="0"
          border_width="0"
          radius="0"/>

    <style name="value_text" text_color="0x1F2A30" text_font="plex_sans_24"/>
    <style name="label_text" text_color="0x5C6B73" />
    <style name="small_text" text_color="0x5C6B73" text_font="plex_sans_12"/>
    <style name="header_text" text_color="0xFFFFFF" text_font="plex_sans_24"/>
    <style name="status_text" text_color="0xFFFFFF" />
  </styles>

  <view>
    <style name="style_main" />

    <!-- Top row -->
    <lv_obj name="time_panel"
            width="148"
            height="40"
            align="top_left"
            x="2"
            y="0"
            scrollbar_mode="off">
      <style name="header_panel" />
      <lv_label name="time" text="Jan 1 00:00" align="center">
        <style name="header_text" />
      </lv_label>
    </lv_obj>

    <lv_obj name="battery_panel"
            width="85"
            height="40"
            align="top_right"
            x="-2"
            y="0"
            scrollbar_mode="off">
      <style name="header_panel" />
      <lv_label name="battery_capacity" text="0%" align="center">
        <style name="header_text" />
      </lv_label>
    </lv_obj>

    <!-- Sensor tiles wrapper -->
    <lv_obj name="ui_tiles_wrap"
            width="236"
            height="240"
            align="top_mid"
            x="0"
            y="43"
            scrollbar_mode="off">
      <style name="wrap_plain" />

      <!-- Row 1 -->
      <lv_obj name="tile_temp"
              width="108"
              height="70"
              align="top_left"
              x="-8"
              y="-4"
              scrollbar_mode="off">
        <style name="tile_panel" />
        <lv_label text="Temp (°C)" align="top_mid" y="-12">
          <style name="label_text" />
        </lv_label>
        <lv_label name="temp_value" text="0" align="center" y="8">
          <style name="value_text" />
        </lv_label>
      </lv_obj>

      <lv_obj name="tile_humidity"
              width="108"
              height="70"
              align="top_right"
              x="8"
              y="-4"
              scrollbar_mode="off">
        <style name="tile_panel" />
        <lv_label text="Humidity (%)" align="top_mid" y="-12">
          <style name="label_text" />
        </lv_label>
        <lv_label name="humidity_value" text="0" align="center" y="8">
          <style name="value_text" />
        </lv_label>
      </lv_obj>

      <!-- Row 2 -->
      <lv_obj name="tile_co2"
              width="108"
              height="70"
              align="top_left"
              x="-8"
              y="71"
              scrollbar_mode="off">
        <style name="tile_panel" />
        <lv_label text="CO2 (ppm)" align="top_mid" y="-12">
          <style name="label_text" />
        </lv_label>
        <lv_label name="co2_value" text="0" align="center" y="8">
          <style name="value_text" />
        </lv_label>
      </lv_obj>

      <lv_obj name="tile_pressure"
              width="108"
              height="70"
              align="top_right"
              x="8"
              y="71"
              scrollbar_mode="off">
        <style name="tile_panel" />
        <lv_label text="Press (hPa)" align="top_mid" y="-12">
          <style name="label_text" />
        </lv_label>
        <lv_label name="pressure_value" text="0" align="center" y="8">
          <style name="value_text" />
        </lv_label>
      </lv_obj>

      <!-- Row 3 -->
      <lv_obj name="tile_eco2"
              width="108"
              height="70"
              align="top_left"
              x="-8"
              y="146"
              scrollbar_mode="off">
        <style name="tile_panel" />
        <lv_label text="eCO2 (ppm)" align="top_mid" y="-12">
          <style name="label_text" />
        </lv_label>
        <lv_label name="eco2_value" text="0" align="center" y="8">
          <style name="value_text" />
        </lv_label>
      </lv_obj>

      <lv_obj name="tile_tvoc"
              width="108"
              height="70"
              align="top_right"
              x="8"
              y="146"
              scrollbar_mode="off">
        <style name="tile_panel" />
        <lv_label text="TVOC (ppb)" align="top_mid" y="-12">
          <style name="label_text" />
        </lv_label>
        <lv_label name="tvoc_value" text="0" align="center" y="8">
          <style name="value_text" />
        </lv_label>
      </lv_obj>
    </lv_obj>

    <!-- Status bar -->
    <lv_obj name="status_bar"
            width="236"
            height="37"
            align="bottom_mid"
            x="0"
            y="0"
            scrollbar_mode="off">
      <style name="status_panel" />
      <lv_label name="status_label" text="Status" align="center">
        <style name="status_text" />
      </lv_label>
    </lv_obj>
  </view>
</screen>