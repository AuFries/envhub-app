<screen>
  <styles>
    <style name="style_main" bg_color="0x00688a" />

    <style name="panel"
          bg_color="0xFFFFFF"
          border_width="1"
          border_color="0x6C8794"
          radius="16"/>
    <!-- pad_left="1"
          pad_right="1"
          pad_top="1"
          pad_bottom="1" 
          /> -->

    <style name="value_text" text_color="0x000000" text_font="plex_sans_24"/>
    <style name="label_text" text_color="0x000000" />
    <style name="small_text" text_color="0x000000" text_font="plex_sans_12"/>
  </styles>

  <view>
    <style name="style_main" />

    <!-- Top row -->
    <lv_obj width="160" height="40" align="top_left" x="2" y="0">
      <style name="panel" />
      <lv_label name="time" text="Jan 1 00:00" align="center">
        <style name="value_text" />
      </lv_label>
    </lv_obj>

    <lv_obj width="80" height="40" align="top_right" x="-2" y="0">
      <style name="panel" />
      <lv_label name="battery_capacity" text="0%" align="center">
        <style name="value_text" />
      </lv_label>
    </lv_obj>

    <!-- Tiles wrapper (positioned once) -->
  <lv_obj name="ui_tiles_wrap" width="240" height="240" align="top_left" x="0" y="43">
      <!-- Temperature -->
    <lv_obj name="tile_temp" width="108" height="70">
      <style name="panel" />
      <lv_label text="Temp (°C)" align="top_mid" y="-12"><style name="label_text" /></lv_label>
      <lv_label name="temp_value" text="0" align="center" x="0" y="5"><style name="value_text" /></lv_label>
    </lv_obj>

      <!-- Humidity -->
    <lv_obj name="tile_humidity" width="108" height="70">
      <style name="panel" />
      <lv_label text="Humidity (%)" align="top_mid" y="-12"><style name="label_text" /></lv_label>
      <lv_label name="humidity_value" text="0" align="center" x="0" y="5"><style name="value_text" /></lv_label>
    </lv_obj>

      <!-- CO2 -->
    <lv_obj name="tile_co2" width="108" height="70">
      <style name="panel" />
      <lv_label text="CO2 (ppm)" align="top_mid" y="-12"><style name="label_text" /></lv_label>
      <lv_label name="co2_value" text="0" align="center" x="0" y="5"><style name="value_text" /></lv_label>
    </lv_obj>

      <!-- Pressure -->
    <lv_obj name="tile_pressure" width="108" height="70">
      <style name="panel" />
      <lv_label text="Press (hPa)" align="top_mid" y="-12"><style name="label_text" /></lv_label>
      <lv_label text="0" align="center" x="0" y="5"><style name="value_text" /></lv_label>
    </lv_obj>

      <!-- eCO2 -->
    <lv_obj name="tile_eco2" width="108" height="70">
      <style name="panel" />
      <lv_label text="eCO2 (ppm)" align="top_mid" y="-12"><style name="label_text" /></lv_label>
      <lv_label text="0" align="center" x="0" y="5"><style name="value_text" /></lv_label>
    </lv_obj>

      <!-- TVOC -->
    <lv_obj name="tile_tvoc" width="108" height="70">
      <style name="panel" />
      <lv_label text="TVOC (ppb)" align="top_mid" x="0" y="-12"><style name="label_text" /></lv_label>
      <lv_label text="0" align="center" x="0" y="5"><style name="value_text" /></lv_label>
    </lv_obj>
  </lv_obj>

    <!-- Status bar -->
    <lv_obj width="240" height="34" align="bottom_mid" x="0" y="0">
      <style name="panel" />
      <lv_label text="Status: {status message}" align="left_mid" x="6">
        <style name="label_text" />
      </lv_label>
    </lv_obj>
  </view>
</screen>