<screen>
  <styles>
    <style name="style_main" bg_color="0xE9EFF2" />

    <style name="header_panel"
          bg_color="0x2C5D6C"
          border_width="0"
          radius="16"/>

    <style name="tile_panel"
          bg_color="0xFFFFFF"
          border_width="1"
          border_color="0xD7E0E5"
          radius="14"/>

    <style name="status_panel"
          bg_color="0x2C5D6C"
          border_width="0"
          radius="16"/>

    <style name="button_panel"
          bg_color="0xFFFFFF"
          border_width="1"
          border_color="0xD7E0E5"
          radius="12"/>

    <style name="wrap_plain"
          bg_opa="0"
          border_width="0"
          radius="0"/>

    <style name="value_text" text_color="0x182126" text_font="plex_sans_24"/>
    <style name="label_text" text_color="0x4F5D65" />
    <style name="small_text" text_color="0x4F5D65" text_font="plex_sans_12"/>
    <style name="header_text" text_color="0xFFFFFF" text_font="plex_sans_24"/>
    <style name="status_text" text_color="0xFFFFFF" />
  </styles>

  <view>
    <style name="style_main" />

    <!-- Top bar -->
    <lv_obj name="secondary_top_row"
            width="236"
            height="42"
            align="top_mid"
            x="0"
            y="2"
            scrollbar_mode="off">
      <style name="header_panel" />

      <lv_button name="secondary_back_btn"
                 width="60"
                 height="30"
                 align="left_mid"
                 x="-5"
                 y="0"
                 scrollbar_mode="off">
        <style name="button_panel" />
        <lv_label name="secondary_back_label" text="" align="center">
          <style name="label_text" />
        </lv_label>
      </lv_button>

      <lv_label text="System Stats" align="center" x="25" y="0">
        <style name="header_text" />
      </lv_label>
    </lv_obj>

    <!-- Presence / uptime strip -->
    <lv_obj name="secondary_status_row"
            width="236"
            height="44"
            align="top_mid"
            x="0"
            y="48"
            scrollbar_mode="off">
      <style name="header_panel" />

      <lv_label text="Presence (%)" align="left_mid" x="7" y="-10">
        <style name="status_text" />
      </lv_label>
      <lv_label name="presence_value" text="0" align="center" x="-55" y="8">
        <style name="header_text" />
      </lv_label>

      <lv_label text="Uptime" align="right_mid" x="-20" y="-10">
        <style name="status_text" />
      </lv_label>
      <lv_label name="uptime_value" text="00:00:00" align="right_mid" x="-5" y="8">
        <style name="header_text" />
      </lv_label>
    </lv_obj>

    <!-- Power / reads group -->
    <lv_obj name="secondary_power_wrap"
            width="236"
            height="112"
            align="top_mid"
            x="0"
            y="96"
            scrollbar_mode="off">
      <style name="wrap_plain" />

      <lv_obj name="tile_batt_voltage"
              width="112"
              height="50"
              align="top_left"
              x="-10"
              y="-10"
              scrollbar_mode="off">
        <style name="tile_panel" />
        <lv_label text="Batt V" align="center" x="0" y="-10">
          <style name="small_text" />
        </lv_label>
        <lv_label name="batt_voltage_value" text="0.00" align="center" x="0" y="10">
          <style name="label_text" />
        </lv_label>
      </lv_obj>

      <lv_obj name="tile_batt_current"
              width="112"
              height="50"
              align="top_right"
              x="10"
              y="-10"
              scrollbar_mode="off">
        <style name="tile_panel" />
        <lv_label text="Batt I (mA)" align="center" x="0" y="-10">
          <style name="small_text" />
        </lv_label>
        <lv_label name="batt_current_value" text="0" align="center" x="0" y="10">
          <style name="label_text" />
        </lv_label>
      </lv_obj>

      <lv_obj name="tile_system_power"
              width="112"
              height="50"
              align="bottom_left"
              x="-10"
              y="10"
              scrollbar_mode="off">
        <style name="tile_panel" />
        <lv_label text="System P (mW)" align="center" x="0" y="-10">
          <style name="small_text" />
        </lv_label>
        <lv_label name="system_power_value" text="0.00" align="center" x="0" y="10">
          <style name="label_text" />
        </lv_label>
      </lv_obj>

      <lv_obj name="tile_sensor_reads"
              width="112"
              height="50"
              align="bottom_right"
              x="10"
              y="10"
              scrollbar_mode="off">
        <style name="tile_panel" />
        <lv_label text="Sensor Reads" align="center" x="0" y="-10">
          <style name="small_text" />
        </lv_label>
        <lv_label name="sensor_reads_value" text="0" align="center" x="0" y="10">
          <style name="label_text" />
        </lv_label>
      </lv_obj>
    </lv_obj>

    <!-- Detailed stats -->
    <lv_obj name="secondary_stats_panel"
            width="236"
            height="104"
            align="bottom_mid"
            x="0"
            y="-4"
            scrollbar_mode="off">
      <style name="tile_panel" />

      <!-- Left column -->
      <lv_label text="Peripherals (mA)" align="top_left" x="12" y="0">
        <style name="small_text" />
      </lv_label>
      <lv_label name="peripheral_current_value" text="0" align="top_left" x="12" y="16">
        <style name="value_text" />
      </lv_label>

      <lv_label text="Compute (mA)" align="top_left" x="12" y="48">
        <style name="small_text" />
      </lv_label>
      <lv_label name="compute_current_value" text="0" align="top_left" x="12" y="64">
        <style name="value_text" />
      </lv_label>

      <!-- Right column -->
      <lv_label text="CPU (%)" align="top_left" x="132" y="0">
        <style name="small_text" />
      </lv_label>
      <lv_label name="cpu_util_value" text="0" align="top_left" x="132" y="16">
        <style name="value_text" />
      </lv_label>

      <lv_label text="Memory (%)" align="top_left" x="132" y="48">
        <style name="small_text" />
      </lv_label>
      <lv_label name="memory_util_value" text="0" align="top_left" x="132" y="64">
        <style name="value_text" />
      </lv_label>
    </lv_obj>
  </view>
</screen>