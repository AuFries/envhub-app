<screen>
  <styles>
    <style name="style_main" bg_color="0x00688a" />

    <style name="panel"
          bg_color="0xFFFFFF"
          border_width="1"
          border_color="0x224455"
          radius="12"
          pad_left="8"
          pad_right="8"
          pad_top="6"
          pad_bottom="6" />

    <style name="value_text" text_color="0x000000" />
    <style name="label_text" text_color="0x000000" />
    <style name="small_text" text_color="0x000000" text_font="plex_sans_12"/>
  </styles>

  <view>
    <style name="style_main" />

    <!-- Top row -->
    <lv_obj width="160" height="34" align="top_left" x="2" y="0">
      <style name="panel" />
      <lv_label text="Wall Time" align="center">
        <style name="value_text" />
      </lv_label>
    </lv_obj>

    <lv_obj width="80" height="34" align="top_right" x="-2" y="0">
      <style name="panel" />
      <lv_label text="🔋 ##%" align="center">
        <style name="value_text" />
      </lv_label>
    </lv_obj>

  <!-- Tiles wrapper (positioned once) -->
  <lv_obj name="ui_tiles_wrap" width="240" height="230" align="top_left" x="0" y="44">
    <!-- Temperature -->
    <lv_obj name="tile_temp" width="110" height="70">
      <style name="panel" />
      <lv_label text="Temperature" align="top_mid" y="2"><style name="label_text" /></lv_label>
      <lv_label text="0°F" align="center" x="-14" y="6"><style name="value_text" /></lv_label>
      <lv_label text="mn 0" align="top_right" x="-4" y="22"><style name="small_text" /></lv_label>
      <lv_label text="mx 0" align="top_right" x="-4" y="38"><style name="small_text" /></lv_label>
      <lv_label text="av 0" align="top_right" x="-4" y="54"><style name="small_text" /></lv_label>
    </lv_obj>

    <!-- Humidity -->
    <lv_obj name="tile_humidity" width="110" height="70">
      <style name="panel" />
      <lv_label text="Humidity" align="top_mid" y="2"><style name="label_text" /></lv_label>
      <lv_label text="0%" align="center" x="-14" y="6"><style name="value_text" /></lv_label>
      <lv_label text="mn 0" align="top_right" x="-4" y="22"><style name="small_text" /></lv_label>
      <lv_label text="mx 0" align="top_right" x="-4" y="38"><style name="small_text" /></lv_label>
      <lv_label text="av 0" align="top_right" x="-4" y="54"><style name="small_text" /></lv_label>
    </lv_obj>

    <!-- CO2 -->
    <lv_obj name="tile_co2" width="110" height="70">
      <style name="panel" />
      <lv_label text="CO2" align="top_mid" y="2"><style name="label_text" /></lv_label>
      <lv_label text="0 ppm" align="center" x="-14" y="6"><style name="value_text" /></lv_label>
      <lv_label text="mn 0" align="top_right" x="-4" y="22"><style name="small_text" /></lv_label>
      <lv_label text="mx 0" align="top_right" x="-4" y="38"><style name="small_text" /></lv_label>
      <lv_label text="av 0" align="top_right" x="-4" y="54"><style name="small_text" /></lv_label>
    </lv_obj>

    <!-- Pressure -->
    <lv_obj name="tile_pressure" width="110" height="70">
      <style name="panel" />
      <lv_label text="Pressure" align="top_mid" y="2"><style name="label_text" /></lv_label>
      <lv_label text="0 hPa" align="center" x="-14" y="6"><style name="value_text" /></lv_label>
      <lv_label text="mn 0" align="top_right" x="-4" y="22"><style name="small_text" /></lv_label>
      <lv_label text="mx 0" align="top_right" x="-4" y="38"><style name="small_text" /></lv_label>
      <lv_label text="av 0" align="top_right" x="-4" y="54"><style name="small_text" /></lv_label>
    </lv_obj>

    <!-- eCO2 -->
    <lv_obj name="tile_eco2" width="110" height="70">
      <style name="panel" />
      <lv_label text="eCO2" align="top_mid" y="2"><style name="label_text" /></lv_label>
      <lv_label text="0 ppm" align="center" x="-14" y="6"><style name="value_text" /></lv_label>
      <lv_label text="mn 0" align="top_right" x="-4" y="22"><style name="small_text" /></lv_label>
      <lv_label text="mx 0" align="top_right" x="-4" y="38"><style name="small_text" /></lv_label>
      <lv_label text="av 0" align="top_right" x="-4" y="54"><style name="small_text" /></lv_label>
    </lv_obj>

    <!-- TVOC -->
    <lv_obj name="tile_tvoc" width="110" height="70">
      <style name="panel" />
      <lv_label text="TVOC" align="top_mid" y="2"><style name="label_text" /></lv_label>
      <lv_label text="0 ppb" align="center" x="-14" y="6"><style name="value_text" /></lv_label>
      <lv_label text="mn 0" align="top_right" x="-4" y="22"><style name="small_text" /></lv_label>
      <lv_label text="mx 0" align="top_right" x="-4" y="38"><style name="small_text" /></lv_label>
      <lv_label text="av 0" align="top_right" x="-4" y="54"><style name="small_text" /></lv_label>
    </lv_obj>
  </lv_obj>

    <!-- Status bar -->
    <lv_obj width="240" height="34" align="bottom_mid" x="0" y="0">
      <style name="panel" />
      <lv_label text="Status: {status message}" align="left_mid" x="6">
        <style name="label_text" />
      </lv_label>
    </lv_obj>
  </view>
</screen>